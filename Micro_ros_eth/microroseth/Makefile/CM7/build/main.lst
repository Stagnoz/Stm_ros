 163:../../CM7/Core/Src/main.c **** #if ENABLE_MICROROS
 164:../../CM7/Core/Src/main.c **** static void StartHeartbeatPublisherTask(void *argument) {
 165:../../CM7/Core/Src/main.c ****   int failure_count = 0;
 166:../../CM7/Core/Src/main.c ****   (void)argument;
 167:../../CM7/Core/Src/main.c **** 
 168:../../CM7/Core/Src/main.c ****   printf("CM7: publisher-task-start\r\n");
 169:../../CM7/Core/Src/main.c **** 
 170:../../CM7/Core/Src/main.c ****   for (;;) {
 171:../../CM7/Core/Src/main.c ****     rcl_ret_t ret = rcl_publish(&heartbeat_publisher, &heartbeat_msg, NULL);
 172:../../CM7/Core/Src/main.c **** 
 173:../../CM7/Core/Src/main.c ****     if (ret == RCL_RET_OK) {
 174:../../CM7/Core/Src/main.c ****       printf("CM7: publish-ok seq=%ld\r\n", (long)heartbeat_msg.data);
 175:../../CM7/Core/Src/main.c ****       heartbeat_msg.data++;
 176:../../CM7/Core/Src/main.c ****       failure_count = 0;
 177:../../CM7/Core/Src/main.c **** 
 178:../../CM7/Core/Src/main.c ****       if (!healthy_publish_seen) {
 179:../../CM7/Core/Src/main.c ****         healthy_publish_seen = true;
 180:../../CM7/Core/Src/main.c ****         SetFirmwareStatus(STATUS_RUNNING_SOLID_GREEN);
 181:../../CM7/Core/Src/main.c ****       }
 182:../../CM7/Core/Src/main.c ****     } else {
 183:../../CM7/Core/Src/main.c ****       failure_count++;
 184:../../CM7/Core/Src/main.c ****       printf("CM7: publish-failed ret=%ld count=%d\r\n", (long)ret,
 185:../../CM7/Core/Src/main.c ****              failure_count);
 186:../../CM7/Core/Src/main.c **** 
 187:../../CM7/Core/Src/main.c ****       if (healthy_publish_seen) {
 188:../../CM7/Core/Src/main.c ****         SetRuntimeFault("publish");
 189:../../CM7/Core/Src/main.c ****       } else if (failure_count >= 10) {
 190:../../CM7/Core/Src/main.c ****         SetStartupFatalError("publish-before-healthy");
 191:../../CM7/Core/Src/main.c ****         while (1) {
 192:../../CM7/Core/Src/main.c ****           osDelay(1000);
