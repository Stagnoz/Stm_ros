 409:../../CM7/LWIP/Target/ethernetif.c **** /**
 410:../../CM7/LWIP/Target/ethernetif.c ****  * @brief This function should do the actual transmission of the packet. The packet is
 411:../../CM7/LWIP/Target/ethernetif.c ****  * contained in the pbuf that is passed to the function. This pbuf
 412:../../CM7/LWIP/Target/ethernetif.c ****  * might be chained.
 413:../../CM7/LWIP/Target/ethernetif.c ****  *
 414:../../CM7/LWIP/Target/ethernetif.c ****  * @param netif the lwip network interface structure for this ethernetif
 415:../../CM7/LWIP/Target/ethernetif.c ****  * @param p the MAC packet to send (e.g. IP packet including MAC addresses and type)
 416:../../CM7/LWIP/Target/ethernetif.c ****  * @return ERR_OK if the packet could be sent
 417:../../CM7/LWIP/Target/ethernetif.c ****  *         an err_t value if the packet couldn't be sent
 418:../../CM7/LWIP/Target/ethernetif.c ****  *
 419:../../CM7/LWIP/Target/ethernetif.c ****  * @note Returning ERR_MEM here if a DMA queue of your MAC is full can lead to
 420:../../CM7/LWIP/Target/ethernetif.c ****  *       strange results. You might consider waiting for space in the DMA queue
 421:../../CM7/LWIP/Target/ethernetif.c ****  *       to become available since the stack doesn't retry to send a packet
 422:../../CM7/LWIP/Target/ethernetif.c ****  *       dropped because of memory failure (except for the TCP timers).
 423:../../CM7/LWIP/Target/ethernetif.c ****  */
 424:../../CM7/LWIP/Target/ethernetif.c **** 
 425:../../CM7/LWIP/Target/ethernetif.c **** static err_t low_level_output(struct netif *netif, struct pbuf *p)
 426:../../CM7/LWIP/Target/ethernetif.c **** {
 427:../../CM7/LWIP/Target/ethernetif.c ****   uint32_t i = 0U;
 428:../../CM7/LWIP/Target/ethernetif.c ****   struct pbuf *q = NULL;
 429:../../CM7/LWIP/Target/ethernetif.c ****   err_t errval = ERR_OK;
 430:../../CM7/LWIP/Target/ethernetif.c ****   ETH_BufferTypeDef Txbuffer[ETH_TX_DESC_CNT] = {0};
 431:../../CM7/LWIP/Target/ethernetif.c **** 
ARM GAS  C:\Users\minis\AppData\Local\Temp\ccKk4sUj.s 			page 9


 432:../../CM7/LWIP/Target/ethernetif.c ****   memset(Txbuffer, 0 , ETH_TX_DESC_CNT*sizeof(ETH_BufferTypeDef));
 433:../../CM7/LWIP/Target/ethernetif.c **** 
 434:../../CM7/LWIP/Target/ethernetif.c ****   for(q = p; q != NULL; q = q->next)
 435:../../CM7/LWIP/Target/ethernetif.c ****   {
 436:../../CM7/LWIP/Target/ethernetif.c ****     if(i >= ETH_TX_DESC_CNT)
 437:../../CM7/LWIP/Target/ethernetif.c ****       return ERR_IF;
 438:../../CM7/LWIP/Target/ethernetif.c **** 
 439:../../CM7/LWIP/Target/ethernetif.c ****     Txbuffer[i].buffer = q->payload;
 440:../../CM7/LWIP/Target/ethernetif.c ****     Txbuffer[i].len = q->len;
 441:../../CM7/LWIP/Target/ethernetif.c **** 
 442:../../CM7/LWIP/Target/ethernetif.c ****     if(i>0)
 443:../../CM7/LWIP/Target/ethernetif.c ****     {
 444:../../CM7/LWIP/Target/ethernetif.c ****       Txbuffer[i-1].next = &Txbuffer[i];
 445:../../CM7/LWIP/Target/ethernetif.c ****     }
 446:../../CM7/LWIP/Target/ethernetif.c **** 
 447:../../CM7/LWIP/Target/ethernetif.c ****     if(q->next == NULL)
 448:../../CM7/LWIP/Target/ethernetif.c ****     {
 449:../../CM7/LWIP/Target/ethernetif.c ****       Txbuffer[i].next = NULL;
 450:../../CM7/LWIP/Target/ethernetif.c ****     }
 451:../../CM7/LWIP/Target/ethernetif.c **** 
 452:../../CM7/LWIP/Target/ethernetif.c ****     i++;
 453:../../CM7/LWIP/Target/ethernetif.c ****   }
 454:../../CM7/LWIP/Target/ethernetif.c **** 
 455:../../CM7/LWIP/Target/ethernetif.c ****   TxConfig.Length = p->tot_len;
 456:../../CM7/LWIP/Target/ethernetif.c ****   TxConfig.TxBuffer = Txbuffer;
 457:../../CM7/LWIP/Target/ethernetif.c ****   TxConfig.pData = p;
 458:../../CM7/LWIP/Target/ethernetif.c **** 
 459:../../CM7/LWIP/Target/ethernetif.c ****   pbuf_ref(p);
 460:../../CM7/LWIP/Target/ethernetif.c **** 
 461:../../CM7/LWIP/Target/ethernetif.c ****   do
 462:../../CM7/LWIP/Target/ethernetif.c ****   {
 463:../../CM7/LWIP/Target/ethernetif.c ****       if(HAL_ETH_Transmit_IT_Safe(&heth, &TxConfig) == HAL_OK)
 464:../../CM7/LWIP/Target/ethernetif.c ****     {
 465:../../CM7/LWIP/Target/ethernetif.c ****       errval = ERR_OK;
 466:../../CM7/LWIP/Target/ethernetif.c ****     }
 467:../../CM7/LWIP/Target/ethernetif.c ****     else
 468:../../CM7/LWIP/Target/ethernetif.c ****     {
 469:../../CM7/LWIP/Target/ethernetif.c **** 
 470:../../CM7/LWIP/Target/ethernetif.c ****       if(HAL_ETH_GetError(&heth) & HAL_ETH_ERROR_BUSY)
 471:../../CM7/LWIP/Target/ethernetif.c ****       {
 472:../../CM7/LWIP/Target/ethernetif.c ****         /* Wait for descriptors to become available */
 473:../../CM7/LWIP/Target/ethernetif.c ****         osSemaphoreAcquire(TxPktSemaphore, ETHIF_TX_TIMEOUT);
 474:../../CM7/LWIP/Target/ethernetif.c ****         HAL_ETH_ReleaseTxPacket(&heth);
 475:../../CM7/LWIP/Target/ethernetif.c ****         errval = ERR_BUF;
 476:../../CM7/LWIP/Target/ethernetif.c ****       }
 477:../../CM7/LWIP/Target/ethernetif.c ****       else
 478:../../CM7/LWIP/Target/ethernetif.c ****       {
 479:../../CM7/LWIP/Target/ethernetif.c ****         /* Other error */
 480:../../CM7/LWIP/Target/ethernetif.c ****         pbuf_free(p);
 481:../../CM7/LWIP/Target/ethernetif.c ****         errval =  ERR_IF;
 482:../../CM7/LWIP/Target/ethernetif.c ****       }
 483:../../CM7/LWIP/Target/ethernetif.c ****     }
 484:../../CM7/LWIP/Target/ethernetif.c ****   }while(errval == ERR_BUF);
 485:../../CM7/LWIP/Target/ethernetif.c **** 
 486:../../CM7/LWIP/Target/ethernetif.c ****   return errval;
 487:../../CM7/LWIP/Target/ethernetif.c **** }
