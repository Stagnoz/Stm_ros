 305:../../CM7/LWIP/Target/ethernetif.c **** // Software reset of LAN8742 PHY to prevent cold-boot startup delays
 306:../../CM7/LWIP/Target/ethernetif.c **** // PHY address is 0 on STM32H755 Nucleo board
 307:../../CM7/LWIP/Target/ethernetif.c **** uint32_t regvalue = 0;
 308:../../CM7/LWIP/Target/ethernetif.c **** uint32_t tickstart = HAL_GetTick();
 309:../../CM7/LWIP/Target/ethernetif.c **** 
 310:../../CM7/LWIP/Target/ethernetif.c **** // Read current BCR value (register 0x00 = Basic Control Register)
 311:../../CM7/LWIP/Target/ethernetif.c **** if(HAL_ETH_ReadPHYRegister(&heth, 0, LAN8742_BCR, &regvalue) == HAL_OK)
 312:../../CM7/LWIP/Target/ethernetif.c **** {
 313:../../CM7/LWIP/Target/ethernetif.c ****     // Set software reset bit (bit 15)
 314:../../CM7/LWIP/Target/ethernetif.c ****     regvalue |= LAN8742_BCR_SOFT_RESET;
 315:../../CM7/LWIP/Target/ethernetif.c ****     HAL_ETH_WritePHYRegister(&heth, 0, LAN8742_BCR, regvalue);
 316:../../CM7/LWIP/Target/ethernetif.c **** 
 317:../../CM7/LWIP/Target/ethernetif.c ****     // Wait for reset to complete (bit auto-clears when done)
ARM GAS  C:\Users\minis\AppData\Local\Temp\ccKk4sUj.s 			page 7


 318:../../CM7/LWIP/Target/ethernetif.c ****     // Maximum wait time: 500ms
 319:../../CM7/LWIP/Target/ethernetif.c ****     do {
 320:../../CM7/LWIP/Target/ethernetif.c ****         HAL_ETH_ReadPHYRegister(&heth, 0, LAN8742_BCR, &regvalue);
 321:../../CM7/LWIP/Target/ethernetif.c ****         if((HAL_GetTick() - tickstart) > 500U)
 322:../../CM7/LWIP/Target/ethernetif.c ****         {
 323:../../CM7/LWIP/Target/ethernetif.c ****             // Timeout - continue anyway
 324:../../CM7/LWIP/Target/ethernetif.c ****             break;
 325:../../CM7/LWIP/Target/ethernetif.c ****         }
 326:../../CM7/LWIP/Target/ethernetif.c ****     } while (regvalue & LAN8742_BCR_SOFT_RESET);
 327:../../CM7/LWIP/Target/ethernetif.c **** 
 328:../../CM7/LWIP/Target/ethernetif.c ****     // Additional settling time after reset
 329:../../CM7/LWIP/Target/ethernetif.c ****     osDelay(50);
 330:../../CM7/LWIP/Target/ethernetif.c **** }
