 159:../../CM7/LWIP/Target/ethernetif.c **** /**
 160:../../CM7/LWIP/Target/ethernetif.c ****   * @brief  Safe wrapper for HAL_ETH_Transmit_IT with memory barriers
 161:../../CM7/LWIP/Target/ethernetif.c ****   * @param  heth: pointer to ETH handle
 162:../../CM7/LWIP/Target/ethernetif.c ****   * @param  pTxConfig: pointer to TX packet configuration
 163:../../CM7/LWIP/Target/ethernetif.c ****   * @retval HAL status
 164:../../CM7/LWIP/Target/ethernetif.c ****   */
 165:../../CM7/LWIP/Target/ethernetif.c **** HAL_StatusTypeDef HAL_ETH_Transmit_IT_Safe(ETH_HandleTypeDef *heth, ETH_TxPacketConfig *pTxConfig)
 166:../../CM7/LWIP/Target/ethernetif.c **** {
 167:../../CM7/LWIP/Target/ethernetif.c ****     // Ensure all descriptor writes complete before starting DMA
 168:../../CM7/LWIP/Target/ethernetif.c ****     __DMB();  // Data Memory Barrier - wait for writes to finish
 169:../../CM7/LWIP/Target/ethernetif.c ****     __DSB();  // Data Synchronization Barrier - flush write buffer
 170:../../CM7/LWIP/Target/ethernetif.c **** 
 171:../../CM7/LWIP/Target/ethernetif.c ****     // Now safe to trigger DMA operation
 172:../../CM7/LWIP/Target/ethernetif.c ****     return HAL_ETH_Transmit_IT(heth, pTxConfig);
 173:../../CM7/LWIP/Target/ethernetif.c **** }
 174:../../CM7/LWIP/Target/ethernetif.c **** /* USER CODE END 3 */
