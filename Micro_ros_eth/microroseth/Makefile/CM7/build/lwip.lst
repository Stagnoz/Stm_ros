  98:../../CM7/LWIP/App/lwip.c **** 
  99:../../CM7/LWIP/App/lwip.c ****   // Gateway Address (your router/hotspot)
 100:../../CM7/LWIP/App/lwip.c ****   GATEWAY_ADDRESS[0] = 0;
