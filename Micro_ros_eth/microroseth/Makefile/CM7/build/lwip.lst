  33:../../CM7/LWIP/App/lwip.c **** u32_t microros_lwip_rand(void)
  34:../../CM7/LWIP/App/lwip.c **** {
  35:../../CM7/LWIP/App/lwip.c ****   static uint32_t state = 0;
  36:../../CM7/LWIP/App/lwip.c **** 
  37:../../CM7/LWIP/App/lwip.c ****   if (state == 0) {
  38:../../CM7/LWIP/App/lwip.c ****     state = 0xA5A5A5A5u ^ HAL_GetTick();
  39:../../CM7/LWIP/App/lwip.c ****     if (state == 0) {
  40:../../CM7/LWIP/App/lwip.c ****       state = 0x1u;
  41:../../CM7/LWIP/App/lwip.c ****     }
  42:../../CM7/LWIP/App/lwip.c ****   }
  43:../../CM7/LWIP/App/lwip.c **** 
  44:../../CM7/LWIP/App/lwip.c ****   /* Xorshift32 is sufficient for LwIP port selection and transaction IDs. */
  45:../../CM7/LWIP/App/lwip.c ****   state ^= state << 13;
  46:../../CM7/LWIP/App/lwip.c ****   state ^= state >> 17;
  47:../../CM7/LWIP/App/lwip.c ****   state ^= state << 5;
  48:../../CM7/LWIP/App/lwip.c **** 
  49:../../CM7/LWIP/App/lwip.c ****   return state;
  50:../../CM7/LWIP/App/lwip.c **** }
  51:../../CM7/LWIP/App/lwip.c **** 
