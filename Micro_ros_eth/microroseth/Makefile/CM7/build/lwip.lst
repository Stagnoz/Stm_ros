  82:../../CM7/LWIP/App/lwip.c **** void MX_LWIP_Init(void)
  83:../../CM7/LWIP/App/lwip.c **** {
  84:../../CM7/LWIP/App/lwip.c ****   /* IP addresses initialization */
  85:../../CM7/LWIP/App/lwip.c ****   // Change from 192.168.1.x to 172.20.10.x subnet
  86:../../CM7/LWIP/App/lwip.c **** 
  87:../../CM7/LWIP/App/lwip.c ****   // STM32 IP Address (choose any free IP on the 172.20.10.x network)
  88:../../CM7/LWIP/App/lwip.c ****   IP_ADDRESS[0] = 192;
  89:../../CM7/LWIP/App/lwip.c ****   IP_ADDRESS[1] = 168;
ARM GAS  C:\Users\minis\AppData\Local\Temp\ccx6Sqdb.s 			page 3


  90:../../CM7/LWIP/App/lwip.c ****   IP_ADDRESS[2] = 0;
  91:../../CM7/LWIP/App/lwip.c ****   IP_ADDRESS[3] = 3;  // ← STM32's IP (not .12 which is Raspberry Pi)
  92:../../CM7/LWIP/App/lwip.c **** 
  93:../../CM7/LWIP/App/lwip.c ****   // Subnet Mask (stays the same)
  94:../../CM7/LWIP/App/lwip.c ****   NETMASK_ADDRESS[0] = 255;
  95:../../CM7/LWIP/App/lwip.c ****   NETMASK_ADDRESS[1] = 255;
  96:../../CM7/LWIP/App/lwip.c ****   NETMASK_ADDRESS[2] = 255;
