 107:../../CM7/LWIP/App/lwip.c **** /* USER CODE END IP_ADDRESSES */
 108:../../CM7/LWIP/App/lwip.c **** 
 109:../../CM7/LWIP/App/lwip.c ****   /* Initialize the LwIP stack with RTOS */
 110:../../CM7/LWIP/App/lwip.c ****   tcpip_init( NULL, NULL );
 111:../../CM7/LWIP/App/lwip.c **** 
 112:../../CM7/LWIP/App/lwip.c ****   /* IP addresses initialization without DHCP (IPv4) */
 113:../../CM7/LWIP/App/lwip.c ****   IP4_ADDR(&ipaddr, IP_ADDRESS[0], IP_ADDRESS[1], IP_ADDRESS[2], IP_ADDRESS[3]);
 114:../../CM7/LWIP/App/lwip.c ****   IP4_ADDR(&netmask, NETMASK_ADDRESS[0], NETMASK_ADDRESS[1] , NETMASK_ADDRESS[2], NETMASK_ADDRESS[3
 115:../../CM7/LWIP/App/lwip.c ****   IP4_ADDR(&gw, GATEWAY_ADDRESS[0], GATEWAY_ADDRESS[1], GATEWAY_ADDRESS[2], GATEWAY_ADDRESS[3]);
 116:../../CM7/LWIP/App/lwip.c **** 
 117:../../CM7/LWIP/App/lwip.c ****   /* add the network interface (IPv4/IPv6) with RTOS */
 118:../../CM7/LWIP/App/lwip.c ****   netif_add(&gnetif, &ipaddr, &netmask, &gw, NULL, &ethernetif_init, &tcpip_input);
 119:../../CM7/LWIP/App/lwip.c **** 
 120:../../CM7/LWIP/App/lwip.c ****   /* Registers the default network interface */
 121:../../CM7/LWIP/App/lwip.c ****   netif_set_default(&gnetif);
 122:../../CM7/LWIP/App/lwip.c **** 
 123:../../CM7/LWIP/App/lwip.c ****   /* We must always bring the network interface up connection or not... */
 124:../../CM7/LWIP/App/lwip.c ****   netif_set_up(&gnetif);
 125:../../CM7/LWIP/App/lwip.c **** 
 126:../../CM7/LWIP/App/lwip.c ****   /* Set the link callback function, this function is called on change of link status*/
 127:../../CM7/LWIP/App/lwip.c ****   netif_set_link_callback(&gnetif, ethernet_link_status_updated);
 128:../../CM7/LWIP/App/lwip.c **** 
 129:../../CM7/LWIP/App/lwip.c ****   /* Create the Ethernet link handler thread */
 130:../../CM7/LWIP/App/lwip.c **** /* USER CODE BEGIN H7_OS_THREAD_NEW_CMSIS_RTOS_V2 */
 131:../../CM7/LWIP/App/lwip.c ****   memset(&attributes, 0x0, sizeof(osThreadAttr_t));
 132:../../CM7/LWIP/App/lwip.c ****   attributes.name = "EthLink";
 133:../../CM7/LWIP/App/lwip.c ****   attributes.stack_size = INTERFACE_THREAD_STACK_SIZE;
 134:../../CM7/LWIP/App/lwip.c ****   attributes.priority = osPriorityBelowNormal;
 135:../../CM7/LWIP/App/lwip.c ****   osThreadNew(ethernet_link_thread, &gnetif, &attributes);
 136:../../CM7/LWIP/App/lwip.c **** /* USER CODE END H7_OS_THREAD_NEW_CMSIS_RTOS_V2 */
