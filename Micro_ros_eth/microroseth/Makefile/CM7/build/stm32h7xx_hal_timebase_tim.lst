  81:../../CM7/Core/Src/stm32h7xx_hal_timebase_tim.c ****    * Counter direction = Up
  82:../../CM7/Core/Src/stm32h7xx_hal_timebase_tim.c ****    */
  83:../../CM7/Core/Src/stm32h7xx_hal_timebase_tim.c ****   htim1.Init.Period = (1000000U / 1000U) - 1U;
  84:../../CM7/Core/Src/stm32h7xx_hal_timebase_tim.c ****   htim1.Init.Prescaler = uwPrescalerValue;
  85:../../CM7/Core/Src/stm32h7xx_hal_timebase_tim.c ****   htim1.Init.ClockDivision = 0;
  86:../../CM7/Core/Src/stm32h7xx_hal_timebase_tim.c ****   htim1.Init.CounterMode = TIM_COUNTERMODE_UP;
