 145:../../CM7/Core/Src/main.c ****   uint32_t poll_count = 0;
 146:../../CM7/Core/Src/main.c ****   /* USER CODE END 2 */
 147:../../CM7/Core/Src/main.c **** 
 148:../../CM7/Core/Src/main.c ****   /* Infinite loop */
 149:../../CM7/Core/Src/main.c ****   /* USER CODE BEGIN WHILE */
 150:../../CM7/Core/Src/main.c ****   while (1)
 151:../../CM7/Core/Src/main.c ****   {
 152:../../CM7/Core/Src/main.c ****     /* Polling: controlla se CM4 ha scritto un dato nuovo */
 153:../../CM7/Core/Src/main.c ****     __DSB(); /* Sincronizza con le scritture del CM4 alla SRAM4 */
 154:../../CM7/Core/Src/main.c ****     SCB_InvalidateDCache_by_Addr((uint32_t *)0x38000000, 32); /* Invalida cache */
 155:../../CM7/Core/Src/main.c **** 
 156:../../CM7/Core/Src/main.c ****     if (SHARED_DATA->data_ready)
 157:../../CM7/Core/Src/main.c ****     {
 158:../../CM7/Core/Src/main.c ****       uint32_t dist = SHARED_DATA->distance_cm;
 159:../../CM7/Core/Src/main.c ****       SHARED_DATA->data_ready = 0U;
 160:../../CM7/Core/Src/main.c ****       __DSB();
 161:../../CM7/Core/Src/main.c ****       printf("CM7 ricevuto: distanza = %lu cm\r\n", dist);
 162:../../CM7/Core/Src/main.c ****     }
 163:../../CM7/Core/Src/main.c **** 
 164:../../CM7/Core/Src/main.c ****     poll_count++;
 165:../../CM7/Core/Src/main.c ****     if (poll_count >= 20) /* ogni ~1 secondo */
 166:../../CM7/Core/Src/main.c ****     {
 167:../../CM7/Core/Src/main.c ****       printf("[DBG] poll=%lu ready=%lu dist=%lu\r\n",
 168:../../CM7/Core/Src/main.c ****              poll_count, (uint32_t)SHARED_DATA->data_ready,
 169:../../CM7/Core/Src/main.c ****              (uint32_t)SHARED_DATA->distance_cm);
 170:../../CM7/Core/Src/main.c ****       poll_count = 0;
 171:../../CM7/Core/Src/main.c ****     }
 172:../../CM7/Core/Src/main.c **** 
 173:../../CM7/Core/Src/main.c ****     HAL_Delay(50); /* polling ogni 50 ms */
 174:../../CM7/Core/Src/main.c **** 
 175:../../CM7/Core/Src/main.c ****     /* USER CODE END WHILE */
 176:../../CM7/Core/Src/main.c **** 
 177:../../CM7/Core/Src/main.c ****     /* USER CODE BEGIN 3 */
 178:../../CM7/Core/Src/main.c ****   }
 179:../../CM7/Core/Src/main.c ****   /* USER CODE END 3 */
 180:../../CM7/Core/Src/main.c **** }
