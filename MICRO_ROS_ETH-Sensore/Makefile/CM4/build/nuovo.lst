  42:../../CM4/Core/Src/nuovo.c **** int main(void)
  43:../../CM4/Core/Src/nuovo.c **** {
  44:../../CM4/Core/Src/nuovo.c ****     /* ------------------------------------------------------------------ */
  45:../../CM4/Core/Src/nuovo.c ****     /* Pre-HAL GPIO: enable GPIOB for LEDs                                */
  46:../../CM4/Core/Src/nuovo.c ****     /* ------------------------------------------------------------------ */
  47:../../CM4/Core/Src/nuovo.c ****     RCC->AHB4ENR |= (1U << 1);
  48:../../CM4/Core/Src/nuovo.c ****     BUSY(10000);
  49:../../CM4/Core/Src/nuovo.c ****     GPIOB->MODER &= ~(3U << 0);   GPIOB->MODER |= (1U << 0);   /* PB0  out */
  50:../../CM4/Core/Src/nuovo.c ****     GPIOB->MODER &= ~(3U << 28);  GPIOB->MODER |= (1U << 28);  /* PB14 out */
  51:../../CM4/Core/Src/nuovo.c **** 
  52:../../CM4/Core/Src/nuovo.c ****     /* Quick alive blink */
  53:../../CM4/Core/Src/nuovo.c ****     for (int j = 0; j < 2; j++) {
  54:../../CM4/Core/Src/nuovo.c ****         LED_GREEN_ON(); LED_RED_ON();
  55:../../CM4/Core/Src/nuovo.c ****         BUSY(3000000);
  56:../../CM4/Core/Src/nuovo.c ****         LED_ALL_OFF();
  57:../../CM4/Core/Src/nuovo.c ****         BUSY(3000000);
  58:../../CM4/Core/Src/nuovo.c ****     }
  59:../../CM4/Core/Src/nuovo.c **** 
  60:../../CM4/Core/Src/nuovo.c ****     HAL_Init();
  61:../../CM4/Core/Src/nuovo.c ****     SystemClock_Config();
  62:../../CM4/Core/Src/nuovo.c ****     SCB->VTOR = 0x08100000;
  63:../../CM4/Core/Src/nuovo.c ****     MX_GPIO_Init();
  64:../../CM4/Core/Src/nuovo.c ****     MX_TIM2_Init();
  65:../../CM4/Core/Src/nuovo.c ****     MX_UART4_Init();
