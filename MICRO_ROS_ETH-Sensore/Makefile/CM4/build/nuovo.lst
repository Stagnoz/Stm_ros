   1:../../CM4/Core/Src/nuovo.c **** /**
   2:../../CM4/Core/Src/nuovo.c ****   ******************************************************************************
   3:../../CM4/Core/Src/nuovo.c ****   * @file           : main_debug.c
   4:../../CM4/Core/Src/nuovo.c ****   * @brief          : JSN-SR04T ultrasonic sensor demo
   5:../../CM4/Core/Src/nuovo.c ****   *
   6:../../CM4/Core/Src/nuovo.c ****   * Sequence:
   7:../../CM4/Core/Src/nuovo.c ****   *   PHASE 1 (5s): TRIG toggles 500ms on/500ms off  → probe PD1 with multimeter
   8:../../CM4/Core/Src/nuovo.c ****   *   PHASE 2 (5s): raw ECHO read → GREEN=HIGH, RED=LOW
   9:../../CM4/Core/Src/nuovo.c ****   *   PHASE 3 (5s): full trigger+echo attempt → GREEN=echo received, RED=timeout
  10:../../CM4/Core/Src/nuovo.c ****   *   PHASE 4:      loop showing distance via blinks (if phase 3 worked)
  11:../../CM4/Core/Src/nuovo.c ****   ******************************************************************************
  12:../../CM4/Core/Src/nuovo.c ****   */
  13:../../CM4/Core/Src/nuovo.c **** 
  14:../../CM4/Core/Src/nuovo.c **** #include "main.h"
  15:../../CM4/Core/Src/nuovo.c **** #include <stdio.h> // Indispensabile per la funzione printf
