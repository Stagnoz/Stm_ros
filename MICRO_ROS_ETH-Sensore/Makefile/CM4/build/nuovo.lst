 191:../../CM4/Core/Src/nuovo.c **** 
 192:../../CM4/Core/Src/nuovo.c ****     /* ================================================================== */
 193:../../CM4/Core/Src/nuovo.c ****     /* PHASE 4: Result                                                     */
 194:../../CM4/Core/Src/nuovo.c ****     /* If any echo was received: distance blinks on green                 */
 195:../../CM4/Core/Src/nuovo.c ****     /* If no echo at all:        solid red forever → debug wiring         */
 196:../../CM4/Core/Src/nuovo.c ****     /* ================================================================== */
 197:../../CM4/Core/Src/nuovo.c ****     if (!any_echo) {
 198:../../CM4/Core/Src/nuovo.c ****         /* Solid red = complete failure, check wiring */
 199:../../CM4/Core/Src/nuovo.c ****         LED_RED_ON();
