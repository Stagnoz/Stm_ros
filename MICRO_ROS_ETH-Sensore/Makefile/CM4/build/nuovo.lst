  17:../../CM4/Core/Src/nuovo.c **** TIM_HandleTypeDef htim2;
  18:../../CM4/Core/Src/nuovo.c **** /* Assicurati che la variabile UART globale generata da CubeMX sia visibile */
  19:../../CM4/Core/Src/nuovo.c **** /* Sostituisci huart1 con l'handle della UART che hai scelto (es. huart3) */
  20:../../CM4/Core/Src/nuovo.c **** UART_HandleTypeDef huart4;
  21:../../CM4/Core/Src/nuovo.c **** 
  22:../../CM4/Core/Src/nuovo.c **** #define TIMER_TARGET_HZ       1000000U
  23:../../CM4/Core/Src/nuovo.c **** #define TRIG_RESET_TIME_US    2U
  24:../../CM4/Core/Src/nuovo.c **** #define TRIG_PULSE_TIME_US    10U
  25:../../CM4/Core/Src/nuovo.c **** #define ECHO_WAIT_TIMEOUT_US  30000U
  26:../../CM4/Core/Src/nuovo.c **** #define ECHO_PULSE_TIMEOUT_US 26000U
  27:../../CM4/Core/Src/nuovo.c **** 
  28:../../CM4/Core/Src/nuovo.c **** #define BUSY(n)  do { for (volatile int _i = 0; _i < (n); _i++); } while(0)
  29:../../CM4/Core/Src/nuovo.c **** 
  30:../../CM4/Core/Src/nuovo.c **** #define LED_GREEN_ON()   (GPIOB->BSRR = (1U <<  0))
  31:../../CM4/Core/Src/nuovo.c **** #define LED_GREEN_OFF()  (GPIOB->BSRR = (1U << 16))
  32:../../CM4/Core/Src/nuovo.c **** #define LED_RED_ON()     (GPIOB->BSRR = (1U << 14))
  33:../../CM4/Core/Src/nuovo.c **** #define LED_RED_OFF()    (GPIOB->BSRR = (1U << 30))
ARM GAS  C:\Users\minis\AppData\Local\Temp\ccEJxbB6.s 			page 2


  34:../../CM4/Core/Src/nuovo.c **** #define LED_ALL_OFF()    do { LED_GREEN_OFF(); LED_RED_OFF(); } while(0)
