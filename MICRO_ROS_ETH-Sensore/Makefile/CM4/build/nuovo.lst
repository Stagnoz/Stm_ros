 165:../../CM4/Core/Src/nuovo.c ****             if ((uint32_t)(__HAL_TIM_GET_COUNTER(&htim2) - wait_start)
 166:../../CM4/Core/Src/nuovo.c ****                     > ECHO_WAIT_TIMEOUT_US) { break; }
 167:../../CM4/Core/Src/nuovo.c ****         }
 168:../../CM4/Core/Src/nuovo.c **** 
 169:../../CM4/Core/Src/nuovo.c ****         if (HAL_GPIO_ReadPin(GPIOD, GPIO_PIN_0) == GPIO_PIN_SET) {
 170:../../CM4/Core/Src/nuovo.c ****             uint32_t echo_start = __HAL_TIM_GET_COUNTER(&htim2);
 171:../../CM4/Core/Src/nuovo.c ****             while (HAL_GPIO_ReadPin(GPIOD, GPIO_PIN_0) == GPIO_PIN_SET) {
 172:../../CM4/Core/Src/nuovo.c ****                 if ((uint32_t)(__HAL_TIM_GET_COUNTER(&htim2) - echo_start)
 173:../../CM4/Core/Src/nuovo.c ****                         > ECHO_PULSE_TIMEOUT_US) { break; }
 174:../../CM4/Core/Src/nuovo.c ****             }
 175:../../CM4/Core/Src/nuovo.c ****             echo_time = (uint32_t)(__HAL_TIM_GET_COUNTER(&htim2) - echo_start);
 176:../../CM4/Core/Src/nuovo.c ****             got_echo = 1U;
 177:../../CM4/Core/Src/nuovo.c ****             any_echo = 1U;
 178:../../CM4/Core/Src/nuovo.c ****         }
 179:../../CM4/Core/Src/nuovo.c **** 
 180:../../CM4/Core/Src/nuovo.c ****         if (got_echo) {
 181:../../CM4/Core/Src/nuovo.c ****             /* GREEN blink = echo received this attempt */
 182:../../CM4/Core/Src/nuovo.c ****             LED_GREEN_ON(); HAL_Delay(300U); LED_GREEN_OFF();
 183:../../CM4/Core/Src/nuovo.c ****         } else {
 184:../../CM4/Core/Src/nuovo.c ****             /* RED blink = no echo this attempt */
 185:../../CM4/Core/Src/nuovo.c ****             LED_RED_ON(); HAL_Delay(300U); LED_RED_OFF();
 186:../../CM4/Core/Src/nuovo.c ****         }
 187:../../CM4/Core/Src/nuovo.c ****         HAL_Delay(200U);
 188:../../CM4/Core/Src/nuovo.c ****     }
