  67:../../CM4/Core/Src/nuovo.c ****     /* Compute prescaler */
  68:../../CM4/Core/Src/nuovo.c ****     uint32_t pclk1   = HAL_RCC_GetPCLK1Freq();
  69:../../CM4/Core/Src/nuovo.c ****     uint32_t apb1pre = (RCC->D2CFGR & RCC_D2CFGR_D2PPRE1_Msk)
  70:../../CM4/Core/Src/nuovo.c ****                         >> RCC_D2CFGR_D2PPRE1_Pos;
  71:../../CM4/Core/Src/nuovo.c ****     uint32_t tim2clk = (apb1pre >= 0x04U) ? (pclk1 * 2U) : pclk1;
  72:../../CM4/Core/Src/nuovo.c ****     uint32_t psc     = (tim2clk / TIMER_TARGET_HZ);
  73:../../CM4/Core/Src/nuovo.c ****     if (psc > 0U) { psc -= 1U; }
  74:../../CM4/Core/Src/nuovo.c ****     __HAL_TIM_SET_PRESCALER(&htim2, psc);
  75:../../CM4/Core/Src/nuovo.c ****     __HAL_TIM_SET_COUNTER(&htim2, 0);
  76:../../CM4/Core/Src/nuovo.c ****     HAL_TIM_GenerateEvent(&htim2, TIM_EVENTSOURCE_UPDATE);
  77:../../CM4/Core/Src/nuovo.c ****     HAL_TIM_Base_Start(&htim2);
  78:../../CM4/Core/Src/nuovo.c **** 
  79:../../CM4/Core/Src/nuovo.c ****     /* Clocks OK — 2 green blinks */
  80:../../CM4/Core/Src/nuovo.c ****     for (int j = 0; j < 2; j++) {
  81:../../CM4/Core/Src/nuovo.c ****         LED_GREEN_ON(); HAL_Delay(200U);
  82:../../CM4/Core/Src/nuovo.c ****         LED_GREEN_OFF(); HAL_Delay(200U);
  83:../../CM4/Core/Src/nuovo.c ****     }
  84:../../CM4/Core/Src/nuovo.c ****     HAL_Delay(500U);
  85:../../CM4/Core/Src/nuovo.c **** 
  86:../../CM4/Core/Src/nuovo.c **** 
  87:../../CM4/Core/Src/nuovo.c ****     /* ================================================================== */
  88:../../CM4/Core/Src/nuovo.c ****     /* PHASE 1: TRIG toggle — probe PD1 with multimeter                   */
  89:../../CM4/Core/Src/nuovo.c ****     /* Expected: ~3.3V / 0V alternating every 500ms                       */
  90:../../CM4/Core/Src/nuovo.c ****     /* Failure:  stuck at 0V → GPIOD clock or MX_GPIO_Init broken         */
ARM GAS  C:\Users\minis\AppData\Local\Temp\ccEJxbB6.s 			page 3


  91:../../CM4/Core/Src/nuovo.c ****     /* ================================================================== */
  92:../../CM4/Core/Src/nuovo.c **** 
  93:../../CM4/Core/Src/nuovo.c ****     /* 1× slow red = entering phase 1 */
  94:../../CM4/Core/Src/nuovo.c ****     LED_RED_ON(); HAL_Delay(1000U); LED_RED_OFF(); HAL_Delay(500U);
  95:../../CM4/Core/Src/nuovo.c **** 
  96:../../CM4/Core/Src/nuovo.c ****     uint32_t phase1_start = HAL_GetTick();
  97:../../CM4/Core/Src/nuovo.c ****     while (HAL_GetTick() - phase1_start < 5000U) {
  98:../../CM4/Core/Src/nuovo.c ****         HAL_GPIO_WritePin(GPIOD, GPIO_PIN_1, GPIO_PIN_SET);
  99:../../CM4/Core/Src/nuovo.c ****         LED_GREEN_ON();
 100:../../CM4/Core/Src/nuovo.c ****         HAL_Delay(500U);
 101:../../CM4/Core/Src/nuovo.c ****         HAL_GPIO_WritePin(GPIOD, GPIO_PIN_1, GPIO_PIN_RESET);
 102:../../CM4/Core/Src/nuovo.c ****         LED_GREEN_OFF();
 103:../../CM4/Core/Src/nuovo.c ****         HAL_Delay(500U);
 104:../../CM4/Core/Src/nuovo.c ****     }
 105:../../CM4/Core/Src/nuovo.c ****     HAL_Delay(1000U);
 106:../../CM4/Core/Src/nuovo.c **** 
 107:../../CM4/Core/Src/nuovo.c **** 
 108:../../CM4/Core/Src/nuovo.c ****     /* ================================================================== */
 109:../../CM4/Core/Src/nuovo.c ****     /* PHASE 2: Raw ECHO read — no trigger sent                           */
 110:../../CM4/Core/Src/nuovo.c ****     /* GREEN = PD0 reads HIGH                                             */
 111:../../CM4/Core/Src/nuovo.c ****     /* RED   = PD0 reads LOW  (expected with PULLDOWN and no signal)      */
 112:../../CM4/Core/Src/nuovo.c ****     /* ================================================================== */
 113:../../CM4/Core/Src/nuovo.c **** 
 114:../../CM4/Core/Src/nuovo.c ****     /* 2× slow red = entering phase 2 */
 115:../../CM4/Core/Src/nuovo.c ****     for (int j = 0; j < 2; j++) {
 116:../../CM4/Core/Src/nuovo.c ****         LED_RED_ON(); HAL_Delay(500U);
 117:../../CM4/Core/Src/nuovo.c ****         LED_RED_OFF(); HAL_Delay(500U);
 118:../../CM4/Core/Src/nuovo.c ****     }
 119:../../CM4/Core/Src/nuovo.c ****     HAL_Delay(500U);
 120:../../CM4/Core/Src/nuovo.c **** 
 121:../../CM4/Core/Src/nuovo.c ****     uint32_t phase2_start = HAL_GetTick();
 122:../../CM4/Core/Src/nuovo.c ****     while (HAL_GetTick() - phase2_start < 5000U) {
 123:../../CM4/Core/Src/nuovo.c ****         if (HAL_GPIO_ReadPin(GPIOD, GPIO_PIN_0) == GPIO_PIN_SET) {
 124:../../CM4/Core/Src/nuovo.c ****             LED_GREEN_ON(); LED_RED_OFF();
 125:../../CM4/Core/Src/nuovo.c ****         } else {
 126:../../CM4/Core/Src/nuovo.c ****             LED_GREEN_OFF(); LED_RED_ON();
 127:../../CM4/Core/Src/nuovo.c ****         }
 128:../../CM4/Core/Src/nuovo.c ****         HAL_Delay(50U);
 129:../../CM4/Core/Src/nuovo.c ****     }
 130:../../CM4/Core/Src/nuovo.c ****     LED_ALL_OFF();
 131:../../CM4/Core/Src/nuovo.c ****     HAL_Delay(5000U);
 132:../../CM4/Core/Src/nuovo.c **** 
 133:../../CM4/Core/Src/nuovo.c **** 
 134:../../CM4/Core/Src/nuovo.c ****     /* ================================================================== */
 135:../../CM4/Core/Src/nuovo.c ****     /* PHASE 3: Full trigger → echo attempt, 10 tries                    */
 136:../../CM4/Core/Src/nuovo.c ****     /* GREEN blink = echo received                                        */
 137:../../CM4/Core/Src/nuovo.c ****     /* RED blink   = timeout                                              */
 138:../../CM4/Core/Src/nuovo.c ****     /* ================================================================== */
 139:../../CM4/Core/Src/nuovo.c **** 
 140:../../CM4/Core/Src/nuovo.c ****     /* 3× slow red = entering phase 3 */
 141:../../CM4/Core/Src/nuovo.c ****     for (int j = 0; j < 3; j++) {
 142:../../CM4/Core/Src/nuovo.c ****         LED_RED_ON(); HAL_Delay(500U);
 143:../../CM4/Core/Src/nuovo.c ****         LED_RED_OFF(); HAL_Delay(500U);
 144:../../CM4/Core/Src/nuovo.c ****     }
 145:../../CM4/Core/Src/nuovo.c ****     HAL_Delay(500U);
 146:../../CM4/Core/Src/nuovo.c **** 
 147:../../CM4/Core/Src/nuovo.c ****     uint8_t any_echo = 0U;
ARM GAS  C:\Users\minis\AppData\Local\Temp\ccEJxbB6.s 			page 4


 148:../../CM4/Core/Src/nuovo.c ****     uint32_t echo_time = 0U;
 149:../../CM4/Core/Src/nuovo.c **** 
 150:../../CM4/Core/Src/nuovo.c ****     for (int attempt = 0; attempt < 10; attempt++) {
 151:../../CM4/Core/Src/nuovo.c ****         /* Trigger */
 152:../../CM4/Core/Src/nuovo.c ****         HAL_GPIO_WritePin(GPIOD, GPIO_PIN_1, GPIO_PIN_RESET);
 153:../../CM4/Core/Src/nuovo.c ****         __HAL_TIM_SET_COUNTER(&htim2, 0);
