 155:../../CM4/Core/Src/nuovo.c **** 
 156:../../CM4/Core/Src/nuovo.c ****         HAL_GPIO_WritePin(GPIOD, GPIO_PIN_1, GPIO_PIN_SET);
 157:../../CM4/Core/Src/nuovo.c ****         __HAL_TIM_SET_COUNTER(&htim2, 0);
 158:../../CM4/Core/Src/nuovo.c ****         while (__HAL_TIM_GET_COUNTER(&htim2) < TRIG_PULSE_TIME_US);
 159:../../CM4/Core/Src/nuovo.c ****         HAL_GPIO_WritePin(GPIOD, GPIO_PIN_1, GPIO_PIN_RESET);
 160:../../CM4/Core/Src/nuovo.c **** 
 161:../../CM4/Core/Src/nuovo.c ****         /* Wait for echo HIGH */
 162:../../CM4/Core/Src/nuovo.c ****         uint8_t got_echo = 0U;
 163:../../CM4/Core/Src/nuovo.c ****         uint32_t wait_start = __HAL_TIM_GET_COUNTER(&htim2);
