 120:../../CM4/Core/Src/main.c ****     LED_GREEN_OFF();
 121:../../CM4/Core/Src/main.c ****     HAL_Delay(500U);
 122:../../CM4/Core/Src/main.c ****   }
 123:../../CM4/Core/Src/main.c ****   HAL_Delay(1000U);
 124:../../CM4/Core/Src/main.c **** 
 125:../../CM4/Core/Src/main.c ****   /* ================================================================== */
