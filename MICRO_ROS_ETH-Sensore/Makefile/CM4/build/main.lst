 284:../../CM4/Core/Src/main.c ****         if ((uint32_t)(__HAL_TIM_GET_COUNTER(&htim2) - es) >
 285:../../CM4/Core/Src/main.c ****             ECHO_PULSE_TIMEOUT_US) {
 286:../../CM4/Core/Src/main.c ****           break;
 287:../../CM4/Core/Src/main.c ****         }
 288:../../CM4/Core/Src/main.c ****       }
 289:../../CM4/Core/Src/main.c ****       echo_time = (uint32_t)(__HAL_TIM_GET_COUNTER(&htim2) - es);
 290:../../CM4/Core/Src/main.c ****       dist_cm = echo_time / 58U;
 291:../../CM4/Core/Src/main.c ****     }
 292:../../CM4/Core/Src/main.c **** 
 293:../../CM4/Core/Src/main.c ****     /* ── Aggiorna shared memory SEMPRE (anche se dist_cm invariato) ── */
 294:../../CM4/Core/Src/main.c ****     SHARED_DATA->distance_cm = dist_cm;
 295:../../CM4/Core/Src/main.c ****     SHARED_DATA->data_ready = 1U;
 296:../../CM4/Core/Src/main.c ****     __DSB(); /* Forza la scrittura a raggiungere SRAM4 */
 297:../../CM4/Core/Src/main.c ****   }
 298:../../CM4/Core/Src/main.c **** }
