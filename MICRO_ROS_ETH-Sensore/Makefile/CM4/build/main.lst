   1:../../CM4/Core/Src/main.c **** /**
   2:../../CM4/Core/Src/main.c ****  ******************************************************************************
   3:../../CM4/Core/Src/main.c ****  * @file           : main_debug.c
   4:../../CM4/Core/Src/main.c ****  * @brief          : JSN-SR04T ultrasonic sensor demo
   5:../../CM4/Core/Src/main.c ****  *
   6:../../CM4/Core/Src/main.c ****  * Sequence:
   7:../../CM4/Core/Src/main.c ****  *   PHASE 1 (5s): TRIG toggles 500ms on/500ms off  → probe PD1 with multimeter
   8:../../CM4/Core/Src/main.c ****  *   PHASE 2 (5s): raw ECHO read → GREEN=HIGH, RED=LOW
   9:../../CM4/Core/Src/main.c ****  *   PHASE 3 (5s): full trigger+echo attempt → GREEN=echo received, RED=timeout
  10:../../CM4/Core/Src/main.c ****  *   PHASE 4:      loop showing distance via blinks (if phase 3 worked)
  11:../../CM4/Core/Src/main.c ****  ******************************************************************************
  12:../../CM4/Core/Src/main.c ****  */
